# Copy this file to .env and fill in your own values
# 1. Get a free MongoDB connection string from https://www.mongodb.com/cloud/atlas
#    (or use a local MongoDB: mongodb://127.0.0.1:27017/appointment-booking)
MONGO_URI=mongodb://127.0.0.1:27017/appointment-booking

# 2. Any random long string works. This is used to sign login tokens.
JWT_SECRET=replace_this_with_a_long_random_string

# 3. Port the backend server runs on
PORT=5000
